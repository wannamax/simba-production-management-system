{
  "name": "simba-pms-backend",
  "version": "2.6.0-J",
  "private": true,
  "description": "Simba Production Management System backend API",
  "main": "server.js",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22 <23",
    "pnpm": "10.14.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "migrate": "node scripts/migrate.js",
    "check": "node --check server.js && find routes middleware config utils scripts tests -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test:integration": "node tests/integration-smoke.js"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "pdfmake": "^0.2.23",
    "pg": "^8.16.3"
  }
}
